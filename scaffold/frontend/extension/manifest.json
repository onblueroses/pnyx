{
  "manifest_version": 3,
  "name": "Pnyx",
  "version": "0.1.0",
  "description": "Listening infrastructure for public discourse, on-device",
  "permissions": ["storage", "offscreen"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/*", "https://x.com/*"],
    "js": ["content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [{
    "resources": ["model/*", "model-slop/*", "detection/*", "offscreen.html", "explore.html", "explore.js", "explore.css"],
    "matches": ["<all_urls>"]
  }]
}
